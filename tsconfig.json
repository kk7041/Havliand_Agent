{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@havliand_agent/ai": ["./packages/ai/src/index.ts"],
			"@havliand_agent/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@havliand_agent/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@havliand_agent/ai/dist/*": ["./packages/ai/src/*"],
			"@havliand_agent/agent-core": ["./packages/agent/src/index.ts"],
			"@havliand_agent/agent-core/*": ["./packages/agent/src/*"],
			"@havliand_agent/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@havliand_agent/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@havliand_agent/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@havliand_agent/orchestrator": ["./packages/orchestrator/src/index.ts"],
			"@havliand_agent/orchestrator/*": ["./packages/orchestrator/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@havliand_agent/tui": ["./packages/tui/src/index.ts"],
			"@havliand_agent/tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["**/dist/**"]
}
